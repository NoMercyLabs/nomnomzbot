# =============================================================================
# NomNomzBot — environment template (self_host_full / Docker quickstart)
# =============================================================================
# Copy this file to .env and fill in the REQUIRED values, then:
#   cp .env.example .env      (./deploy.sh and .\deploy.ps1 do this for you)
#   docker compose up -d --build
#
# NEVER commit your .env — it holds your secrets. Only .env.example is tracked.
#
# Every value here is read by docker-compose.yml. The dev defaults are safe for
# local use; CHANGE every secret before exposing the bot to the internet.
# =============================================================================

# --- Twitch (REQUIRED — the bot will not function without these) -------------
# Create an app at https://dev.twitch.tv/console/apps and register exactly one
# OAuth redirect URL: {API_BASE_URL}/api/v1/auth/twitch/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# The Twitch username of the account the bot posts chat as.
TWITCH_BOT_USERNAME=NomNomzBot

# --- Security keys (REQUIRED in production) ----------------------------------
# JWT signing key (>= 32 chars). Generate with: openssl rand -base64 32
JWT_SECRET=dev-secret-key-at-least-32-characters-long!!
JWT_ISSUER=nomnomzbot
JWT_AUDIENCE=nomnomzbot
# AES key for OAuth token storage. Generate with: openssl rand -base64 32
# Changing this invalidates all stored OAuth tokens (the bot must re-auth).
ENCRYPTION_KEY=ZGV2LWVuY3J5cHRpb24ta2V5LWZvci1sb2NhbC1kZXY=

# --- Database (PostgreSQL) ---------------------------------------------------
POSTGRES_USER=nomnomzbot
# Generate with: openssl rand -hex 32 — do NOT keep the dev default in production.
POSTGRES_PASSWORD=nomnomzbot_dev
POSTGRES_DB=nomnomzbot

# --- Redis -------------------------------------------------------------------
# Optional password. Generate with: openssl rand -hex 32. When set, Redis
# requires it and the API appends it to the connection string automatically.
REDIS_PASSWORD=

# --- API base URL ------------------------------------------------------------
# The public URL the API is reachable at. Twitch OAuth redirect URIs are derived
# from this — register only {API_BASE_URL}/api/v1/auth/twitch/callback.
# Twitch requires HTTPS for real logins (use a tunnel/proxy for a public URL).
API_BASE_URL=http://localhost:5080

# --- First admin (optional) --------------------------------------------------
# Your numeric Twitch *user id* (not the login name). The matching account is
# promoted to platform admin on its next login. Leave blank once an admin exists.
INITIAL_ADMIN_TWITCH_ID=

# --- Trusted proxy (X-Forwarded-For) -----------------------------------------
# The API trusts the forwarded client IP ONLY from the proxy in front of it.
# Leave blank when the proxy runs on the host (loopback is trusted by default).
# Set to the proxy's docker network when it reaches the API over the bridge,
# e.g. 172.16.0.0/12 for the default docker bridge range.
TRUSTED_PROXY_NETWORKS=

# --- Optional: Spotify (music integration) -----------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Optional: Discord -------------------------------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Optional: YouTube (music provider) --------------------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- Optional: Text-to-speech ------------------------------------------------
AZURE_TTS_API_KEY=
AZURE_TTS_REGION=westeurope
ELEVENLABS_API_KEY=

# --- Deployment mode ---------------------------------------------------------
# self_host_full (default) — single-tenant Postgres+Redis stack.
# saas — multi-tenant SaaS mode (requires strong JWT_SECRET + ENCRYPTION_KEY).
DEPLOYMENT_MODE=self_host_full

# --- Container image (optional) ----------------------------------------------
# Leave as-is to build the image locally with `up -d --build` (uses root Dockerfile
# which also builds the Wasm frontend). To pull the pre-built CI image instead:
#   API_IMAGE=ghcr.io/stoney_eagle/nomnomzbot:latest
# and remove the `build:` section (or just use `--no-build`).
API_IMAGE=nomnomzbot-api:local

# --- Host port overrides (optional) ------------------------------------------
# Change any of these if a default port is already in use on your machine.
API_HTTP_PORT=5080
API_HTTPS_PORT=5081
POSTGRES_PORT=5432
REDIS_PORT=6379
ADMINER_PORT=8082
