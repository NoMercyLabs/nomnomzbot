    <string name="setup_step_twitch_app_title">Verbind je Twitch-applicatie</string>
    <string name="setup_step_twitch_app_description">De bot communiceert met Twitch via je eigen Twitch-app. Maak er een aan en plak de gegevens.</string>
    <string name="setup_step_twitch_app_instruction_1">Open de Twitch Developer Console op https://dev.twitch.tv/console/apps en registreer een nieuwe applicatie.</string>
