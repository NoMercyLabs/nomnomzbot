    <string name="setup_step_twitch_app_instruction_3">Kies de categorie "Chat Bot", maak de app aan en kopieer vervolgens de Client ID en genereer een Client Secret.</string>
    <string name="setup_step_platform_bot_title">Autoriseer het botaccount</string>
    <string name="setup_step_platform_bot_description">Meld je aan met het Twitch-account waarmee de bot in de chat post en keur de chatrechten goed.</string>
