# =============================================================================
# NomNomzBot Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# (deploy.sh / deploy.ps1 / `npm run setup` do this for you automatically.)
#
# Never commit the .env file to source control — it holds your secrets.
#
# The defaults below are safe for local development. CHANGE every secret
# before deploying to production. When running without Docker (`dotnet run`),
# dev defaults come from appsettings.json instead.
# =============================================================================

# --- Security keys (REQUIRED in production) ----------------------------------
# Generate with: openssl rand -base64 64
JWT_SECRET=dev-secret-key-at-least-32-characters-long!!
JWT_ISSUER=nomnomzbot
JWT_AUDIENCE=nomnomzbot
# AES key for OAuth token storage. Generate with: openssl rand -base64 32
# Changing this invalidates all stored OAuth tokens (bot must re-auth).
ENCRYPTION_KEY=ZGV2LWVuY3J5cHRpb24ta2V5LWZvci1sb2NhbC1kZXY=

# --- Database ----------------------------------------------------------------
POSTGRES_USER=nomnomzbot
# Generate with: openssl rand -hex 32 — do NOT keep the dev default in production.
POSTGRES_PASSWORD=nomnomzbot_dev
POSTGRES_DB=nomnomzbot
# Full connection string used by the API container. Overrides the host/user/db
# above when set. Leave blank to let the compose file build it from the parts.
DATABASE_URL=

# --- Redis -------------------------------------------------------------------
# Generate with: openssl rand -hex 32. When set, Redis requires this password.
REDIS_PASSWORD=
# Full Redis connection string used by the API container. Leave blank to use
# the in-network default (redis://redis:6379).
REDIS_URL=

# --- Twitch (REQUIRED) -------------------------------------------------------
# Get from: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BOT_USERNAME=NomNomzBot

# --- API URL -----------------------------------------------------------------
# Public base URL the API is reachable at. Twitch OAuth redirect URIs are
# computed from this automatically — register only:
#   {API_BASE_URL}/api/v1/auth/twitch/callback
# Example: https://api.yourdomain.com  (Twitch OAuth requires HTTPS for real logins)
API_BASE_URL=http://localhost:5080

# --- First admin (optional) --------------------------------------------------
# Your own Twitch *user id* (numeric, not the login name). The matching account is
# promoted to platform admin on its next login — no raw SQL needed. Leave blank
# after the first admin exists. Find your id at e.g. https://www.streamweasels.com/tools/convert-twitch-username-to-user-id/
INITIAL_ADMIN_TWITCH_ID=

# --- Deployment --------------------------------------------------------------
# self-hosted = single streamer; saas = multi-tenant hosted
DEPLOYMENT_MODE=self-hosted

# --- Cloudflare Tunnel (optional) --------------------------------------------
# Provides HTTPS without a reverse proxy. Leave blank to skip the cloudflared
# service. Get a token at: https://one.dash.cloudflare.com/ -> Networks -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# --- Optional: Spotify -------------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Optional: Discord -------------------------------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Optional: YouTube -------------------------------------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- Optional: TTS -----------------------------------------------------------
AZURE_TTS_API_KEY=
AZURE_TTS_REGION=westeurope
ELEVENLABS_API_KEY=

# --- Host port overrides (optional) ------------------------------------------
# Change if a default port is already in use on your machine.
API_HTTP_PORT=5080
API_HTTPS_PORT=5081
POSTGRES_PORT=5432
REDIS_PORT=6379
ADMINER_PORT=8082
